# ERP Mode: "mock" uses generated data, "live" uses real Entersoft API
ERP_MODE=mock

# Entersoft API Configuration (required when ERP_MODE=live)
ENTERSOFT_BASE_URL=https://api.entersoft.gr
ENTERSOFT_BRANCH_ID=01100128469
ENTERSOFT_ESHOP_API_KEY=          # x-ES-APIKEY-qbizeshopconnector header
ENTERSOFT_ROUTE_ID=               # {routeid} URL parameter
ENTERSOFT_SUBSCRIPTION_ID=        # POST /api/Login/Login/
ENTERSOFT_SUBSCRIPTION_PASSWORD=
ENTERSOFT_ERP_USER=
ENTERSOFT_ERP_PASSWORD=

# AI
ANTHROPIC_API_KEY=

# Sync (for admin/sync endpoint protection)
SYNC_SECRET=change-me-before-use

# Set these after first live sync
ERP_ITEM_COUNT=
ERP_LAST_SYNC=
